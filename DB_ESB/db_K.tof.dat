K.tof.tof0.detmap =
		1 3 0 15 250 0

K.tof.tof0.nelem = 8
K.tof.tof0.position = 0.0 0.0 0.0
K.tof.tof0.size = 1.0 0.1 0.02
K.tof.tof0.angle = 0 0 0
